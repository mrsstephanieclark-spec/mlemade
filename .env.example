# Environment Variables
# Copy this file to .env and fill in the values

# Firebase Configuration (optional - for future Firebase SDK features)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=mle-made
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Booking URL (external booking platform)
VITE_BOOKING_URL=https://booking.mlemade.com

# Instagram API (for future integration)
VITE_INSTAGRAM_ACCESS_TOKEN=
VITE_INSTAGRAM_USER_ID=

# Google Maps
VITE_GOOGLE_MAPS_EMBED_URL=
